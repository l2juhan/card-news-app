{
  "name": "card-news-app",
  "version": "0.1.0",
  "description": "Instagram 카드뉴스 생성/편집/내보내기 Electron 데스크톱 앱",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outdir=dist/main --external:electron --external:puppeteer",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --outdir=dist/preload --external:electron",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "wait-on": "^9.0.4"
  }
}
